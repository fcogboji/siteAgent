generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String    @id @default(cuid())
  clerkId                   String    @unique
  email                     String?
  companyName               String?
  isAdmin                   Boolean   @default(false)
  stripeCustomerId          String?   @unique
  stripeSubscriptionId      String?
  stripeSubscriptionStatus  String?   // trialing | active | past_due | canceled | unpaid
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  jobs                      Job[]
}

model Job {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  clientName  String?
  address     String?
  notes       String?    // general job notes
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  photos      Photo[]
  signature   Signature?
  reportSlug  String?    @unique // for shareable link e.g. r_abc123
}

model Photo {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  imageUrl  String
  note      String?
  tag       String?  // "before" | "after" | "condition" (damage protection / initial state)
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
}

model Signature {
  id                 String   @id @default(cuid())
  jobId              String   @unique
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  signatureImageUrl  String
  signedBy           String?
  createdAt          DateTime @default(now())
}
