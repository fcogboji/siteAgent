generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String    @id @default(cuid())
  clerkId                   String    @unique
  email                     String?
  name                      String?   // firstName + lastName from Clerk
  companyName               String?
  isAdmin                   Boolean   @default(false)
  suspended                 Boolean   @default(false) // admin can suspend/restore
  stripeCustomerId          String?   @unique
  stripeSubscriptionId      String?
  stripeSubscriptionStatus  String?   // trialing | active | past_due | canceled | unpaid
  plan                      String?   // starter | pro | team (from Stripe checkout metadata)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  jobs                      Job[]
  teamOwned                 Team?     // team plan owner
  teamMemberships           TeamMember[]
  teamInvitesSent           TeamInvite[]
  activitiesPerformed       Activity[]
  jobTemplates              JobTemplate[]
}

model Activity {
  id        String   @id @default(cuid())
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  action    String   // job_created | photo_added | notes_updated | signature_added | report_generated
  createdAt DateTime @default(now())
}

model Team {
  id            String   @id @default(cuid())
  ownerId       String   @unique // one team per owner
  name          String?
  logoUrl       String?  // for company branding on reports
  companyContact String? // phone/email for report footer
  createdAt     DateTime @default(now())
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members       TeamMember[]
  invites       TeamInvite[]
  jobTemplates  JobTemplate[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      String   @default("member") // "admin" | "member" — admin can invite/remove
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([teamId, userId])
}

model TeamInvite {
  id        String   @id @default(cuid())
  teamId    String
  inviterId String
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter   User     @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  @@unique([teamId, email])
}

model JobTemplate {
  id           String   @id @default(cuid())
  name         String
  title        String
  clientName   String?
  address      String?
  defaultNotes String?
  userId       String?  // personal template
  teamId       String?  // team template (Team plan only)
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  team         Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Job {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities            Activity[]
  title                 String
  clientName            String?
  address               String?
  notes                 String?    // general job notes
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  photos                Photo[]
  signature             Signature?
  reportSlug            String?    @unique // for shareable link e.g. r_abc123
  clientSignToken       String?    @unique // one-time link for client to sign (cleared after sign)
  clientSignedAt        DateTime?  // when client signed via sign link
  clientSignatureUrl    String?    // client's signature image (data URL or blob URL)
  clientSignedBy        String?    // name client entered when signing
}

model Photo {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  imageUrl  String
  note      String?
  tag       String?  // "before" | "after" | "condition" (damage protection / initial state)
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // suspend | restore | cancel_sub | restore_sub | delete | bulk_suspend | bulk_restore
  targetId   String?  // userId or comma-separated ids
  details    String?  // JSON or free text
  createdAt  DateTime @default(now())
}

model Signature {
  id                 String   @id @default(cuid())
  jobId              String   @unique
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  signatureImageUrl  String
  signedBy           String?
  createdAt          DateTime @default(now())
}
