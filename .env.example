# Database (Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_SECRET_KEY="sk_..."

# Stripe
STRIPE_SECRET_KEY="sk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_TEAM_PRICE_ID="price_..."
# Optional: yearly plans
# STRIPE_STARTER_PRICE_ID_YEARLY="price_..."
# STRIPE_PRO_PRICE_ID_YEARLY="price_..."
# STRIPE_TEAM_PRICE_ID_YEARLY="price_..."

# App URL (required for checkout redirects, report links, invite emails)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Optional: Vercel Blob for photo storage (larger uploads). Without it, images stored inline (max ~6MB).
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Optional: Resend for invite emails
# RESEND_API_KEY="re_..."
# RESEND_FROM="Site Agent <onboarding@resend.dev>"

# Optional: Admin emails (comma-separated). Or set role in Clerk / User.isAdmin in DB.
# ADMIN_EMAILS="admin@example.com,other@example.com"
